---
import '@/styles/global.css';
import Header from '@/components/landing/Header.tsx';
import Hero from '@/components/landing/Hero.tsx';
import Features from '@/components/landing/Features.tsx';
import HowItWorks from '@/components/landing/HowItWorks.tsx';
import Comparison from '@/components/landing/Comparison.tsx';
import CTA from '@/components/landing/CTA.tsx';
import Footer from '@/components/landing/Footer.tsx';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Twinspeak - Break Language Barriers</title>
		<script is:inline>
			(function () {
				try {
					var theme = localStorage.getItem('vite-ui-theme') || 'dark';
					if (theme === 'system') {
						theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
					}
					document.documentElement.classList.add(theme);
				} catch (e) {}
			})();
		</script>
	</head>
	<body class="bg-black text-white overflow-x-hidden">
		<Header client:load />
		<Hero client:load />
		<Features client:load />
		<HowItWorks client:load />
		<Comparison client:load />
		<CTA client:load />
		<Footer client:load />
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		padding: 0;
	}
</style>
